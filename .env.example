# ==============================================================================
# FIFAFlow AI: 2026 World Cup Operations Platform - Environment Variables
# ==============================================================================

# Gemini GenAI Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL database settings (Overridden in Docker Compose to use 'db')
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fifaflow

# Redis Broker (Overridden in Docker Compose to use 'redis')
REDIS_URL=redis://localhost:6379/0

# JWT Auth parameters
JWT_SECRET=fifaflow_ai_jwt_secret_key_2026_super_secure
ENV=development
